{
  // manage the runs of renovate
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekends",
    ":automergeAll",
    ":maintainLockFilesWeekly",
    ":widenPeerDependencies"
  ],
  "labels": [
    "dependencies"
  ],
  "minimumReleaseAge": "1 week",
  "postUpdateOptions": [
    "pnpmDedupe"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "*"
      ],
      "rangeStrategy": "replace"
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "rangeStrategy": "bump"
    }
  ]
}
